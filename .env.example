# Explorer — LLM Configuration
# Copy this file to .env and fill in the values.
#
#   cp .env.example .env

# LLM provider: "ollama" or "openai"
EXPLORER_LLM_PROVIDER=ollama

# Model name (provider-specific)
EXPLORER_LLM_MODEL=nemotron-3-super:120b

# Base URL for the LLM API.
# Ollama default: http://localhost:11434
# OpenAI default: https://api.openai.com/v1
EXPLORER_LLM_BASE_URL=http://localhost:11434

# Temperature (0.0 = deterministic)
EXPLORER_LLM_TEMPERATURE=0.0

# Maximum plan-code-verify iterations per run (0 = unlimited)
EXPLORER_MAX_ITERATIONS=20

# OpenAI API key (only required when EXPLORER_LLM_PROVIDER=openai)
# OPENAI_API_KEY=sk-...

# --- Prompt Customisation ---------------------------------------------------
# Each node uses a system prompt loaded from a Markdown file.
# Override the paths below to fine-tune the agent's behaviour.
# Paths are relative to the project root (or absolute).

# EXPLORER_PROMPT_PLANNER=prompts/planner.md
# EXPLORER_PROMPT_CODER=prompts/coder.md
# EXPLORER_PROMPT_REFLECTOR=prompts/reflector.md
# EXPLORER_PROMPT_FINDINGS=prompts/findings.md

# ── LangSmith tracing (optional) ────────────
# Enable LangChain tracing for debugging / monitoring.
# Requires: pip install langsmith
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=ls-...
# LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
# LANGCHAIN_PROJECT=explorer